# App
APP_NAME=MailProbe
PUBLIC_BASE_URL=http://localhost:8080
HTTP_LISTEN_ADDR=:8080
SMTP_LISTEN_ADDR=:2525
SMTP_DOMAIN=mx-test.example.org

# Container image from CI registry (adjust owner/repo)
MAILPROBE_IMAGE=ghcr.io/brightcolor/mailprobe:latest

# Runtime paths
DATA_DIR=/data
DB_PATH=/data/mailprobe.db

# Lifetime & cleanup
MAILBOX_TTL=24h
DATA_RETENTION_TTL=168h
CLEANUP_INTERVAL=30m

# Abuse protection
MAX_MESSAGE_BYTES=2097152
MAX_ACTIVE_MAILBOXES_PER_IP=20
MAX_ACTIVE_MAILBOXES_GLOBAL=2000
WEB_RATE_LIMIT_PER_MIN=60
WEB_BURST_PER_10_SEC=20
SMTP_RATE_LIMIT_PER_HOUR=200
SMTP_BURST_PER_MIN=40

# Optional checks
ENABLE_RBL_CHECKS=false
RBL_PROVIDERS=zen.spamhaus.org,bl.spamcop.net
ENABLE_SPAMASSASSIN=false
SPAMASSASSIN_HOSTPORT=spamd:783
ENABLE_RSPAMD=false
RSPAMD_URL=http://rspamd:11334/checkv2
RSPAMD_PASSWORD=
ENABLE_REDIS=false
REDIS_ADDR=redis:6379

# Optional alerting webhook (JSON POST on processing failures)
ALERT_WEBHOOK_URL=

# Runtime ports mapped by docker-compose
HTTP_PORT=8080
SMTP_PORT=2525
